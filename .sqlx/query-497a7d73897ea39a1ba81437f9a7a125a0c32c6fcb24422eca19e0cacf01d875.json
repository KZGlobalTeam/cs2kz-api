{
  "db_name": "MySQL",
  "query": "SELECT\n           c.id AS `id: CourseId`,\n           c.name,\n           cf.nub_tier AS `nub_tier: Tier`,\n           cf.pro_tier AS `pro_tier: Tier`,\n           cf.state AS `state: CourseFilterState`\n         FROM Courses AS c\n         JOIN CourseFilters AS cf ON cf.course_id = c.id\n         JOIN Maps AS m ON m.id = c.map_id\n         WHERE c.name LIKE ?\n         AND cf.mode = ?\n         AND m.name LIKE COALESCE(?, m.name)",
